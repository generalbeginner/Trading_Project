//@version=6
indicator("Double QMP Filter + Fibonacci Retracement + Divergence", shorttitle = "Codex", overlay = true, max_bars_back = 1000, max_lines_count = 400, max_labels_count = 400)
import TradingView/ZigZag/7 as zigzag
import michaelpbgilbride/MPBGTradingLibrary/1 as mpbg

indicatorToggle = input.string("Double QMP", "Which indicator do you want to see?", options = ["Double QMP", "Fibonacci"], group = "INDICATOR SELECTION")
showQMP = indicatorToggle == "Double QMP"
showFibonacci = indicatorToggle == "Fibonacci"

sourceMACD = input.source(close, "MACD Source (dflt: close)", group = "Source Settings for QMP FILTER")
sourceQQE = input.source(close, "QQE Adv Source (dflt: close)", group = "Source Settings for QMP FILTER")

fastLength = input.int(12, "Fast (dflt: 12)", step = 1, group = "MACD Settings for QMP FILTER")
slowLength = input.int(26, "Slow (dflt: 26)", step = 1, group = "MACD Settings for QMP FILTER")
smoothInput = input.int(9, "Smooth (dflt: 9)", step = 1, group = "MACD Settings for QMP FILTER")
[macdLine, signalLine, _] = mpbg.macd(sourceMACD, fastLength, slowLength, smoothInput, "DEMA")

rsiPeriodA = input.int(8, "RSI Period (dflt: 8)", step = 1, group = "QQE Settings for QMP FILTER")
sfA = input.int(1, "SF (dflt: 1)", step = 1, group = "QQE Settings for QMP FILTER")
wpA = input.float(3.0, "WP (dflt: 3)", step = 0.25, group = "QQE Settings for QMP FILTER")
showSecondQQE = input.bool(true, "Show Second QQE Avd", group = "QQE Settings for QMP FILTER")
rsiPeriodB = input.int(10, "RSI Period (dflt: 10)", step = 1, group = "QQE Settings for QMP FILTER")
sfB = input.int(14, "SF (dflt: 14)", step = 1, group = "QQE Settings for QMP FILTER")
wpB = input.float(2.0, "WP (dflt: 2)", step = 0.25, group = "QQE Settings for QMP FILTER")
[upSwitchA, downSwitchA] = mpbg.qqeQmpSignals(sourceQQE, rsiPeriodA, sfA, wpA, "EMA", "RSI", macdLine, signalLine)
[upSwitchB, downSwitchB] = mpbg.qqeQmpSignals(sourceQQE, rsiPeriodB, sfB, wpB, "EMA", "RSI", macdLine, signalLine)

plotchar(showQMP and upSwitchA, char = "*", color = color.rgb(51, 204, 225), size = size.small, location = location.belowbar, title = "1. Buy Signal")
plotchar(showQMP and downSwitchA, char = "*", color = color.rgb(237, 220, 89), size = size.small, location = location.abovebar, title = "1. Sell Signal")
plotchar(showQMP and showSecondQQE and upSwitchB ? 1 : na, char = "+", color = color.rgb(51, 164, 216), size = size.small, location = location.belowbar, title = "2. Buy Signal")
plotchar(showQMP and showSecondQQE and downSwitchB ? 1 : na, char = "+", color = color.rgb(217, 165, 77), size = size.small, location = location.abovebar, title = "2. Sell Signal")

showMAs = input.bool(true, "Show Moving Averages", group = "MA Settings")
ema50 = ta.ema(close, input.int(50, "Short EMA (dflt: 50)", step = 1, group = "MA Settings"))
ema100 = ta.ema(close, input.int(100, "Middle EMA (dflt: 100)", step = 1, group = "MA Settings"))
wma240 = ta.wma(close, input.int(240, "Long WMA (dflt: 240)", step = 1, group = "MA Settings"))
plot(showQMP and showMAs ? ema50 : na, color = color.orange, title = "Short EMA", linewidth = 2)
plot(showQMP and showMAs ? ema100 : na, color = color.purple, title = "Middle EMA", linewidth = 2)
plot(showQMP and showMAs ? wma240 : na, color = color.blue, title = "Long WMA", linewidth = 2)

lengthA = input.int(20, "Length (dflt: 20)", step = 1, minval = 1, group = "BOLLINGER BANDS Settings")
maTypeA = input.string("SMA", "Basis MA Type (dflt: SMA)", options = ["SMA", "EMA", "RMA", "WMA", "VWMA"], group = "BOLLINGER BANDS Settings")
srcA = input(close, "Source (dflt: close)", group = "BOLLINGER BANDS Settings")
multA = input.float(2.0, "Std Dev (dflt: 2.0)", step = 0.25, minval = 0.001, maxval = 50, group = "BOLLINGER BANDS Settings")
colourA = input.color(color.rgb(240, 175, 142), "BB Colour", group = "BOLLINGER BANDS Settings")
colourABack = input.color(color.rgb(240, 175, 142, 96), "BB Background", group = "BOLLINGER BANDS Settings")
[basisA, upperA, lowerA] = mpbg.bollinger(srcA, lengthA, multA, maTypeA)
plot(showQMP ? basisA : na, "1. BB Basis", color = colourA, style = plot.style_circles)
p1A = plot(showQMP ? upperA : na, "1. BB Upper", color = colourA, style = plot.style_circles)
p2A = plot(showQMP ? lowerA : na, "1. BB Lower", color = colourA, style = plot.style_circles)
fill(p1A, p2A, color = showQMP ? colourABack : na)

showSecondBB = input.bool(false, "Show Second Bollinger Band", group = "BOLLINGER BANDS Settings")
lengthB = input.int(80, "Length (dflt: 80)", step = 1, minval = 1, group = "BOLLINGER BANDS Settings")
maTypeB = input.string("SMA", "Basis MA Type (dflt: SMA)", options = ["SMA", "EMA", "RMA", "WMA", "VWMA"], group = "BOLLINGER BANDS Settings")
srcB = input(close, "Source (dflt: close)", group = "BOLLINGER BANDS Settings")
multB = input.float(3.0, "Std Dev (dflt: 3.0)", step = 0.25, minval = 0.001, maxval = 50, group = "BOLLINGER BANDS Settings")
colourB = input.color(color.rgb(252, 171, 136), "BB Colour", group = "BOLLINGER BANDS Settings")
colourBBack = input.color(color.rgb(252, 171, 136, 96), "BB Background", group = "BOLLINGER BANDS Settings")
[basisB, upperB, lowerB] = mpbg.bollinger(srcB, lengthB, multB, maTypeB)
plot(showQMP and showSecondBB ? basisB : na, "2. BB Basis", color = colourB, style = plot.style_circles)
p1B = plot(showQMP and showSecondBB ? upperB : na, "2. BB Upper", color = colourB, style = plot.style_circles)
p2B = plot(showQMP and showSecondBB ? lowerB : na, "2. BB Lower", color = colourB, style = plot.style_circles)
fill(p1B, p2B, color = showQMP and showSecondBB ? colourBBack : na)

alertcondition(upSwitchA or upSwitchB, title = "QMP Buy", message = "BUY")
alertcondition(downSwitchA or downSwitchB, title = "QMP Sell", message = "SELL")

// Auto Fibonacci Retracement
devTooltip = "Deviation is a multiplier that affects how much the price should deviate from the previous pivot in order for the bar to become a new pivot."
depthTooltip = "The minimum number of bars that will be taken into account when calculating the indicator."
thresholdMultiplier = input.float(3, "Deviation", minval = 0, tooltip = devTooltip, group = "Fibonacci Retracement Settings")
depth = input.int(10, "Depth", minval = 2, tooltip = depthTooltip, group = "Fibonacci Retracement Settings")
reverse = input(false, "Reverse", display = display.none, group = "Fibonacci Retracement Settings")
extendLeft = input(false, "Extend Left     |     Extend Right", inline = "Extend Lines", group = "Fibonacci Retracement Settings")
extendRight = input(true, "", inline = "Extend Lines", group = "Fibonacci Retracement Settings")
prices = input(true, "Show Prices", display = display.none, group = "Fibonacci Retracement Settings")
levels = input(true, "Show Levels", inline = "Levels", display = display.none, group = "Fibonacci Retracement Settings")
levelsFormat = input.string("Values", "", options = ["Values", "Percent"], inline = "Levels", display = display.none, group = "Fibonacci Retracement Settings")
labelsPosition = input.string("Left", "Labels Position", options = ["Left", "Right"], display = display.none, group = "Fibonacci Retracement Settings")
backgroundTransparency = input.int(95, "Background Transparency", minval = 0, maxval = 100, display = display.none, group = "Fibonacci Retracement Settings")
extending = extendLeft and extendRight ? extend.both : extendLeft ? extend.left : extendRight ? extend.right : extend.none

updateFib() =>
    var settings = zigzag.Settings.new(thresholdMultiplier, depth, color(na), false, false, false, false, "Absolute", true)
    var zigzag.ZigZag zigZag = zigzag.newInstance(settings)
    var zigzag.Pivot lastPivot = na
    var float startPrice = na
    var float height = na
    settings.devThreshold := ta.atr(10) / close * 100 * thresholdMultiplier
    if zigZag.update()
        lastPivot := zigZag.lastPivot()
        if not na(lastPivot)
            var line lastLine = na
            if na(lastLine)
                lastLine := line.new(lastPivot.start, lastPivot.end, xloc = xloc.bar_time, color = color.gray, width = 1, style = line.style_dashed)
            else
                line.set_first_point(lastLine, lastPivot.start)
                line.set_second_point(lastLine, lastPivot.end)
            startPrice := reverse ? lastPivot.start.price : lastPivot.end.price
            endPrice = reverse ? lastPivot.end.price : lastPivot.start.price
            height := (startPrice > endPrice ? -1 : 1) * math.abs(startPrice - endPrice)
    [lastPivot, startPrice, height]

[lastPivot, fibStartPrice, fibHeight] = updateFib()

drawFibLine(price, col) =>
    var id = line.new(lastPivot.start.time, lastPivot.start.price, time, price, xloc = xloc.bar_time, color = col, width = 1, extend = extending)
    line.set_xy1(id, lastPivot.start.time, price)
    line.set_xy2(id, lastPivot.end.time, price)
    id

drawFibLabel(price, txt, txtColor) =>
    x = labelsPosition == "Left" ? lastPivot.start.time : not extendRight ? lastPivot.end.time : time
    labelStyle = labelsPosition == "Left" ? label.style_label_right : label.style_label_left
    align = labelsPosition == "Left" ? text.align_right : text.align_left
    labelText = labelsPosition == "Left" ? txt + "\n" : "       " + txt + "\n"
    var id = label.new(x = x, y = price, xloc = xloc.bar_time, text = labelText, textcolor = txtColor, style = labelStyle, textalign = align, color = #00000000)
    label.set_xy(id, x, price)
    label.set_text(id, labelText)
    label.set_textcolor(id, txtColor)

fibLabelText(level, price) =>
    levelText = levelsFormat == "Values" ? str.tostring(level) : str.tostring(level * 100) + "%"
    (levels ? levelText : "") + (prices ? "(" + str.tostring(price, format.mintick) + ")" : "")

processFibLevel(show, value, levelColor, lineIdOther) =>
    price = mpbg.fibPrice(fibStartPrice, fibHeight, value)
    crossed = mpbg.crossingLevel(close, price)
    if showFibonacci and show and not na(lastPivot)
        lineId = drawFibLine(price, levelColor)
        drawFibLabel(price, fibLabelText(value, price), levelColor)
        if crossed
            alert("Autofib: " + syminfo.ticker + " crossing level " + str.tostring(value))
        if not na(lineIdOther)
            linefill.new(lineId, lineIdOther, color = color.new(levelColor, backgroundTransparency))
        lineId
    else
        lineIdOther

showFibNeg618 = input(true, "", inline = "Fib0", display = display.none), valueFibNeg618 = input(-0.618, "", inline = "Fib0", display = display.none), colorFibNeg618 = input(#009688, "", inline = "Fib0", display = display.none)
showFibNeg382 = input(true, "", inline = "Fib1", display = display.none), valueFibNeg382 = input(-0.382, "", inline = "Fib1", display = display.none), colorFibNeg382 = input(#81c784, "", inline = "Fib1", display = display.none)
showFibNeg236 = input(true, "", inline = "Fib1", display = display.none), valueFibNeg236 = input(-0.236, "", inline = "Fib1", display = display.none), colorFibNeg236 = input(#f44336, "", inline = "Fib1", display = display.none)
showFib0 = input(true, "", inline = "Fib2", display = display.none), valueFib0 = input(0.0, "", inline = "Fib2", display = display.none), colorFib0 = input(#787b86, "", inline = "Fib2", display = display.none)
showFib236 = input(true, "", inline = "Fib2", display = display.none), valueFib236 = input(0.236, "", inline = "Fib2", display = display.none), colorFib236 = input(#f44336, "", inline = "Fib2", display = display.none)
showFib382 = input(true, "", inline = "Fib3", display = display.none), valueFib382 = input(0.382, "", inline = "Fib3", display = display.none), colorFib382 = input(#81c784, "", inline = "Fib3", display = display.none)
showFib5 = input(true, "", inline = "Fib3", display = display.none), valueFib5 = input(0.5, "", inline = "Fib3", display = display.none), colorFib5 = input(#4caf50, "", inline = "Fib3", display = display.none)
showFib618 = input(true, "", inline = "Fib4", display = display.none), valueFib618 = input(0.618, "", inline = "Fib4", display = display.none), colorFib618 = input(#009688, "", inline = "Fib4", display = display.none)
showFib786 = input(true, "", inline = "Fib4", display = display.none), valueFib786 = input(0.786, "", inline = "Fib4", display = display.none), colorFib786 = input(#64b5f6, "", inline = "Fib4", display = display.none)
showFib1 = input(true, "", inline = "Fib5", display = display.none), valueFib1 = input(1.0, "", inline = "Fib5", display = display.none), colorFib1 = input(#787b86, "", inline = "Fib5", display = display.none)
showFib1618 = input(false, "", inline = "Fib5", display = display.none), valueFib1618 = input(1.618, "", inline = "Fib5", display = display.none), colorFib1618 = input(#2962ff, "", inline = "Fib5", display = display.none)

fibLine0 = processFibLevel(showFibNeg618, valueFibNeg618, colorFibNeg618, line(na))
fibLine1 = processFibLevel(showFibNeg382, valueFibNeg382, colorFibNeg382, fibLine0)
fibLine2 = processFibLevel(showFibNeg236, valueFibNeg236, colorFibNeg236, fibLine1)
fibLine3 = processFibLevel(showFib0, valueFib0, colorFib0, fibLine2)
fibLine4 = processFibLevel(showFib236, valueFib236, colorFib236, fibLine3)
fibLine5 = processFibLevel(showFib382, valueFib382, colorFib382, fibLine4)
fibLine6 = processFibLevel(showFib5, valueFib5, colorFib5, fibLine5)
fibLine7 = processFibLevel(showFib618, valueFib618, colorFib618, fibLine6)
fibLine8 = processFibLevel(showFib786, valueFib786, colorFib786, fibLine7)
fibLine9 = processFibLevel(showFib1, valueFib1, colorFib1, fibLine8)
fibLine10 = processFibLevel(showFib1618, valueFib1618, colorFib1618, fibLine9)

// Divergence for custom indicators
divPrd = input.int(5, "Pivot Period", minval = 1, maxval = 50, group = "Divergence Settings")
divSourceMode = input.string("Close", "Source for Pivot Points", options = ["Close", "High & Low"], group = "Divergence Settings")
divSearch = input.string("Regular & Hidden", "Divergence Type", options = ["Regular & Hidden", "Regular", "Hidden"], group = "Divergence Settings")
divShowLimit = input.int(1, "Minimum Number of Divergence", minval = 1, maxval = 4, group = "Divergence Settings")
divMaxpp = input.int(10, "Maximum Pivot Points to Check", minval = 1, maxval = 20, group = "Divergence Settings")
divMaxbars = input.int(100, "Maximum Bars to Check", minval = 30, maxval = 200, group = "Divergence Settings")
divDontConfirm = input.bool(false, "Don't Wait for Confirmation", group = "Divergence Settings")
divShowPivot = input.bool(false, "Show Pivot Points", group = "Divergence Settings")
divShowLines = input.bool(true, "Show Divergence Lines", group = "Divergence Settings")
divShowLabels = input.bool(true, "Show Labels", group = "Divergence Settings")
divLabelGap = input.float(0.002, "Label Gap", step = 0.0005, group = "Divergence Settings")

divCalcMacd = input.bool(true, "MACD Platinum", group = "Divergence Indicators")
divCalcQQE = input.bool(true, "QQE Advanced", group = "Divergence Indicators")
divCalcRsi = input.bool(true, "RSI", group = "Divergence Indicators")
divCalcStoch = input.bool(true, "Stochastic", group = "Divergence Indicators")
divCalcWGRC = input.bool(true, "Weighted Green-Red Count", group = "Divergence Indicators")
divCalcExt = input.bool(false, "External Indicator", group = "Divergence Indicators")
divExternal = input.source(close, "External Source", group = "Divergence Indicators")

divMacdSrc = input.source(close, "Source", group = "Divergence MACD Platinum")
divMacdFast = input.int(12, "Fast", minval = 1, group = "Divergence MACD Platinum")
divMacdSlow = input.int(26, "Slow", minval = 1, group = "Divergence MACD Platinum")
divMacdSmooth = input.int(9, "Smooth", minval = 1, group = "Divergence MACD Platinum")
divMacdValueMode = input.string("MACD Line", "Divergence Value", options = ["MACD Line", "Signal Line", "Histogram"], group = "Divergence MACD Platinum")

divQqeSrc = input.source(close, "Source", group = "Divergence QQE Advanced")
divQqeRsiLen = input.int(10, "RSI Period", minval = 1, group = "Divergence QQE Advanced")
divQqeSf = input.int(14, "SF", minval = 1, group = "Divergence QQE Advanced")
divQqeWp = input.float(2.0, "WP", step = 0.025, group = "Divergence QQE Advanced")
divQqeValueMode = input.string("RSI MA", "Divergence Value", options = ["RSI MA", "Trailing Line", "RSI MA - Trailing Line"], group = "Divergence QQE Advanced")

divRsiSrc = input.source(close, "Source", group = "Divergence RSI")
divRsiLen = input.int(14, "RSI Period", minval = 1, group = "Divergence RSI")

divStochKLen = input.int(14, "%K Length", minval = 1, group = "Divergence Stochastic")
divStochSmoothK = input.int(3, "%K Smoothing", minval = 1, group = "Divergence Stochastic")
divStochDLen = input.int(3, "%D Smoothing", minval = 1, group = "Divergence Stochastic")
divStochValueMode = input.string("%K", "Divergence Value", options = ["%K", "%D", "%K - %D"], group = "Divergence Stochastic")

divWgrcWeighting = input.string("WMA", "Weighting MA", options = ["WMA", "HMA", "EHMA"], group = "Divergence WGRC")
divWgrcLen = input.int(14, "Length", minval = 1, group = "Divergence WGRC")
divWgrcSignal = input.string("Binary", "Signal Calculation", options = ["Binary", "Candle Body", "Normalised Body"], group = "Divergence WGRC")
divWgrcSmoothing = input.string("SMA", "Smoothing MA", options = ["SMA", "EMA", "DEMA", "TEMA", "WMA", "HMA", "EHMA", "Zero-Lag Weak", "SuperSmoother"], group = "Divergence WGRC")
divWgrcSmooth = input.int(3, "Smoothing Factor", minval = 2, group = "Divergence WGRC")
divWgrcValueMode = input.string("WGRC", "Divergence Value", options = ["WGRC", "Smoothed WGRC", "WGRC - Smoothed WGRC"], group = "Divergence WGRC")

divPosRegColor = input.color(color.rgb(175, 213, 171, 33), "Positive Regular Divergence", group = "Divergence Types")
divNegRegColor = input.color(color.rgb(223, 107, 145, 33), "Negative Regular Divergence", group = "Divergence Types")
divPosHidColor = input.color(color.rgb(0, 230, 118, 33), "Positive Hidden Divergence", group = "Divergence Types")
divNegHidColor = input.color(color.rgb(255, 82, 82, 33), "Negative Hidden Divergence", group = "Divergence Types")
divRegStyleInput = input.string("Solid", "Regular Divergence Line Style", options = ["Solid", "Dashed", "Dotted"], group = "Divergence Types")
divHidStyleInput = input.string("Solid", "Hidden Divergence Line Style", options = ["Solid", "Dashed", "Dotted"], group = "Divergence Types")
divRegWidth = input.int(2, "Regular Divergence Line Width", minval = 1, maxval = 5, group = "Divergence Types")
divHidWidth = input.int(1, "Hidden Divergence Line Width", minval = 1, maxval = 5, group = "Divergence Types")

float divPh = ta.pivothigh(divSourceMode == "Close" ? close : high, divPrd, divPrd)
float divPl = ta.pivotlow(divSourceMode == "Close" ? close : low, divPrd, divPrd)
plotshape(divShowPivot ? divPh : na, text = "H", title = "Divergence Pivot High", style = shape.labeldown, color = color.new(color.white, 100), textcolor = color.red, location = location.abovebar, offset = -divPrd)
plotshape(divShowPivot ? divPl : na, text = "L", title = "Divergence Pivot Low", style = shape.labelup, color = color.new(color.white, 100), textcolor = color.lime, location = location.belowbar, offset = -divPrd)

var divPhPositions = array.new_int(20, 0)
var divPlPositions = array.new_int(20, 0)
var divPhVals = array.new_float(20, 0.0)
var divPlVals = array.new_float(20, 0.0)
if not na(divPh)
    array.unshift(divPhPositions, bar_index), array.unshift(divPhVals, divPh)
    array.pop(divPhPositions), array.pop(divPhVals)
if not na(divPl)
    array.unshift(divPlPositions, bar_index), array.unshift(divPlVals, divPl)
    array.pop(divPlPositions), array.pop(divPlVals)

divPosRegOrPosHid(src, cond) =>
    divlen = 0
    priceSrc = divSourceMode == "Close" ? close : low
    if divDontConfirm or src > src[1] or close > close[1]
        start = divDontConfirm ? 0 : 1
        for x = 0 to divMaxpp - 1
            len = bar_index - array.get(divPlPositions, x) + divPrd
            if array.get(divPlPositions, x) == 0 or len > divMaxbars
                break
            ok = len > 5 and ((cond == 1 and src[start] > src[len] and priceSrc[start] < nz(array.get(divPlVals, x))) or (cond == 2 and src[start] < src[len] and priceSrc[start] > nz(array.get(divPlVals, x))))
            if ok
                slope1 = (src[start] - src[len]) / (len - start)
                virtual1 = src[start] - slope1
                slope2 = (close[start] - close[len]) / (len - start)
                virtual2 = close[start] - slope2
                arrived = true
                for y = 1 + start to len - 1
                    if src[y] < virtual1 or nz(close[y]) < virtual2
                        arrived := false
                        break
                    virtual1 -= slope1
                    virtual2 -= slope2
                if arrived
                    divlen := len
                    break
    divlen

divNegRegOrNegHid(src, cond) =>
    divlen = 0
    priceSrc = divSourceMode == "Close" ? close : high
    if divDontConfirm or src < src[1] or close < close[1]
        start = divDontConfirm ? 0 : 1
        for x = 0 to divMaxpp - 1
            len = bar_index - array.get(divPhPositions, x) + divPrd
            if array.get(divPhPositions, x) == 0 or len > divMaxbars
                break
            ok = len > 5 and ((cond == 1 and src[start] < src[len] and priceSrc[start] > nz(array.get(divPhVals, x))) or (cond == 2 and src[start] > src[len] and priceSrc[start] < nz(array.get(divPhVals, x))))
            if ok
                slope1 = (src[start] - src[len]) / (len - start)
                virtual1 = src[start] - slope1
                slope2 = (close[start] - nz(close[len])) / (len - start)
                virtual2 = close[start] - slope2
                arrived = true
                for y = 1 + start to len - 1
                    if src[y] > virtual1 or nz(close[y]) > virtual2
                        arrived := false
                        break
                    virtual1 -= slope1
                    virtual2 -= slope2
                if arrived
                    divlen := len
                    break
    divlen

divCalculate(enabled, indicator) =>
    active = enabled
    posReg = active and (divSearch == "Regular" or divSearch == "Regular & Hidden") ? divPosRegOrPosHid(indicator, 1) : 0
    negReg = active and (divSearch == "Regular" or divSearch == "Regular & Hidden") ? divNegRegOrNegHid(indicator, 1) : 0
    posHid = active and (divSearch == "Hidden" or divSearch == "Regular & Hidden") ? divPosRegOrPosHid(indicator, 2) : 0
    negHid = active and (divSearch == "Hidden" or divSearch == "Regular & Hidden") ? divNegRegOrNegHid(indicator, 2) : 0
    [posReg, negReg, posHid, negHid]

[divMacdLine, divMacdSignal, divMacdHist] = mpbg.macd(divMacdSrc, divMacdFast, divMacdSlow, divMacdSmooth, "DEMA")
divMacdValue = divMacdValueMode == "Signal Line" ? divMacdSignal : divMacdValueMode == "Histogram" ? divMacdHist : divMacdLine
[divQqeRsiMa, divQqeTrailing] = mpbg.qqeLines(divQqeSrc, divQqeRsiLen, divQqeSf, divQqeWp, "EMA", "RSI")
divQqeValue = divQqeValueMode == "Trailing Line" ? divQqeTrailing : divQqeValueMode == "RSI MA - Trailing Line" ? divQqeRsiMa - divQqeTrailing : divQqeRsiMa
divRsiValue = ta.rsi(divRsiSrc, divRsiLen)
[divStochK, divStochD] = mpbg.stochastic(divStochKLen, divStochSmoothK, divStochDLen)
divStochValue = divStochValueMode == "%D" ? divStochD : divStochValueMode == "%K - %D" ? divStochK - divStochD : divStochK
[divWgrc, divSmoothWgrc] = mpbg.weightedGreenRedCount(divWgrcLen, divWgrcSignal, divWgrcWeighting, divWgrcSmooth, divWgrcSmoothing)
divWgrcValue = divWgrcValueMode == "Smoothed WGRC" ? divSmoothWgrc : divWgrcValueMode == "WGRC - Smoothed WGRC" ? divWgrc - divSmoothWgrc : divWgrc

var divNames = array.from("MACD Platinum", "QQE Advanced", "RSI", "Stoch", "WGRC", "External")
var divColors = array.from(divPosRegColor, divNegRegColor, divPosHidColor, divNegHidColor)
var divAll = array.new_int(24, 0)
var divPosLines = array.new_line()
var divNegLines = array.new_line()

divSet(idx, enabled, value) =>
    [posReg, negReg, posHid, negHid] = divCalculate(enabled, value)
    array.set(divAll, idx * 4, posReg)
    array.set(divAll, idx * 4 + 1, negReg)
    array.set(divAll, idx * 4 + 2, posHid)
    array.set(divAll, idx * 4 + 3, negHid)
    [posReg > 0, negReg > 0, posHid > 0, negHid > 0]

[divPr0, divNr0, divPh0, divNh0] = divSet(0, divCalcMacd, divMacdValue)
[divPr1, divNr1, divPh1, divNh1] = divSet(1, divCalcQQE, divQqeValue)
[divPr2, divNr2, divPh2, divNh2] = divSet(2, divCalcRsi, divRsiValue)
[divPr3, divNr3, divPh3, divNh3] = divSet(3, divCalcStoch, divStochValue)
[divPr4, divNr4, divPh4, divNh4] = divSet(4, divCalcWGRC, divWgrcValue)
[divPr5, divNr5, divPh5, divNh5] = divSet(5, divCalcExt, divExternal)

divTotal = 0
for divI = 0 to array.size(divAll) - 1
    divTotal += array.get(divAll, divI) > 0 ? 1 : 0
if divTotal < divShowLimit
    array.fill(divAll, 0)

divTopText = ""
divBottomText = ""
divTopCount = 0
divBottomCount = 0
divTopColor = color.white
divBottomColor = color.white
divDistances = array.new_int(0)
divStart = divDontConfirm ? 0 : 1

for divIdx = 0 to 5
    divTopHit = false
    divBottomHit = false
    for divType = 0 to 3
        divLen = array.get(divAll, divIdx * 4 + divType)
        if divLen > 0
            isPositive = divType == 0 or divType == 2
            if isPositive
                divBottomHit := true
                divBottomColor := array.get(divColors, divType)
            else
                divTopHit := true
                divTopColor := array.get(divColors, divType)
            if not array.includes(divDistances, divLen)
                array.push(divDistances, divLen)
                if divShowLines
                    divLine = line.new(bar_index - divLen, isPositive ? low[divLen] : high[divLen], bar_index - divStart, isPositive ? low[divStart] : high[divStart], color = array.get(divColors, divType), style = divType < 2 ? mpbg.lineStyle(divRegStyleInput) : mpbg.lineStyle(divHidStyleInput), width = divType < 2 ? divRegWidth : divHidWidth)
                    if isPositive
                        array.push(divPosLines, divLine)
                    else
                        array.push(divNegLines, divLine)
    if divTopHit
        divTopCount += 1
        divTopText += array.get(divNames, divIdx) + "\n"
    if divBottomHit
        divBottomCount += 1
        divBottomText += array.get(divNames, divIdx) + "\n"

if divShowLabels
    if divTopCount > 0
        label.new(bar_index, math.max((1.0 + divLabelGap) * high, (1.0 + divLabelGap) * high[1]), divTopText + str.tostring(divTopCount), color = divTopColor, textcolor = color.white, style = label.style_label_down)
    if divBottomCount > 0
        label.new(bar_index, math.min((1.0 - divLabelGap) * low, (1.0 - divLabelGap) * low[1]), divBottomText + str.tostring(divBottomCount), color = divBottomColor, textcolor = color.white, style = label.style_label_up)

divDetectedType(divType) =>
    detected = false
    for divIdx = 0 to 5
        detected := detected or array.get(divAll, divIdx * 4 + divType) > 0
    detected

divPosRegDetected = divDetectedType(0)
divNegRegDetected = divDetectedType(1)
divPosHidDetected = divDetectedType(2)
divNegHidDetected = divDetectedType(3)
alertcondition(divPosRegDetected, title = "Positive Regular Divergence Detected", message = "Positive Regular Divergence Detected")
alertcondition(divNegRegDetected, title = "Negative Regular Divergence Detected", message = "Negative Regular Divergence Detected")
alertcondition(divPosHidDetected, title = "Positive Hidden Divergence Detected", message = "Positive Hidden Divergence Detected")
alertcondition(divNegHidDetected, title = "Negative Hidden Divergence Detected", message = "Negative Hidden Divergence Detected")
