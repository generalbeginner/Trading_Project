//@version=6
indicator("Divergence for Many Indicators", shorttitle = "DfMI", overlay = true, max_bars_back = 1000, max_lines_count = 400, max_labels_count = 400)
import michaelpbgilbride/MPBGTradingLibrary/1 as mpbg

prd = input.int(5, "Pivot Period", minval = 1, maxval = 50, group = "Divergence Settings")
sourceMode = input.string("Close", "Source for Pivot Points", options = ["Close", "High & Low"], group = "Divergence Settings")
searchDiv = input.string("Regular & Hidden", "Divergence Type", options = ["Regular & Hidden", "Regular", "Hidden"], group = "Divergence Settings")
showLimit = input.int(1, "Minimum Number of Divergence", minval = 1, maxval = 4, group = "Divergence Settings")
maxpp = input.int(10, "Maximum Pivot Points to Check", minval = 1, maxval = 20, group = "Divergence Settings")
maxbars = input.int(100, "Maximum Bars to Check", minval = 30, maxval = 200, group = "Divergence Settings")
dontConfirm = input.bool(false, "Don't Wait for Confirmation", group = "Divergence Settings")
showPivot = input.bool(false, "Show Pivot Points", group = "Divergence Settings")
showLines = input.bool(true, "Show Divergence Lines", group = "Divergence Settings")
showLabels = input.bool(true, "Show Labels", group = "Divergence Settings")
divLabelGap = input.float(0.002, "Label Gap", step = 0.0005, group = "Divergence Settings")

calcMacdPlatinum = input.bool(true, "MACD Platinum", group = "Divergence Indicators")
calcQQEAdvanced = input.bool(true, "QQE Advanced", group = "Divergence Indicators")
calcRsi = input.bool(true, "RSI", group = "Divergence Indicators")
calcStoch = input.bool(true, "Stochastic", group = "Divergence Indicators")
calcWGRC = input.bool(true, "Weighted Green-Red Count", group = "Divergence Indicators")
calcExt = input.bool(false, "External Indicator", group = "Divergence Indicators")
externalIndi = input.source(close, "External Source", group = "Divergence Indicators")

macdSrc = input.source(close, "Source", group = "Divergence MACD Platinum")
macdFast = input.int(12, "Fast", minval = 1, group = "Divergence MACD Platinum")
macdSlow = input.int(26, "Slow", minval = 1, group = "Divergence MACD Platinum")
macdSmooth = input.int(9, "Smooth", minval = 1, group = "Divergence MACD Platinum")
macdMaType = input.string("DEMA", "Smoothing Function", options = ["EMA", "DEMA", "TEMA", "HMA", "EHMA", "Zero-Lag Weak", "SuperSmoother"], group = "Divergence MACD Platinum")
macdDivValue = input.string("MACD Line", "Divergence Value", options = ["MACD Line", "Signal Line", "Histogram"], group = "Divergence MACD Platinum")

qqeSrc = input.source(close, "Source", group = "Divergence QQE Advanced")
qqeRsiLen = input.int(10, "RSI Period", minval = 1, group = "Divergence QQE Advanced")
qqeSf = input.int(14, "SF", minval = 1, group = "Divergence QQE Advanced")
qqeWp = input.float(2.0, "WP", step = 0.025, group = "Divergence QQE Advanced")
qqeMaType = input.string("EMA", "Smoothing Function", options = ["EMA", "DEMA", "TEMA", "HMA", "EHMA", "Zero-Lag Weak", "SuperSmoother"], group = "Divergence QQE Advanced")
qqeDivValue = input.string("RSI MA", "Divergence Value", options = ["RSI MA", "Trailing Line", "RSI MA - Trailing Line"], group = "Divergence QQE Advanced")

rsiSrc = input.source(close, "Source", group = "Divergence RSI")
rsiLen = input.int(14, "RSI Period", minval = 1, group = "Divergence RSI")

stochKLen = input.int(14, "%K Length", minval = 1, group = "Divergence Stochastic")
stochSmoothK = input.int(3, "%K Smoothing", minval = 1, group = "Divergence Stochastic")
stochDLen = input.int(3, "%D Smoothing", minval = 1, group = "Divergence Stochastic")
stochDivValue = input.string("%K", "Divergence Value", options = ["%K", "%D", "%K - %D"], group = "Divergence Stochastic")

wgrcWeightingType = input.string("WMA", "Weighting MA", options = ["WMA", "HMA"], group = "Divergence WGRC")
wgrcLen = input.int(14, "Length", minval = 1, group = "Divergence WGRC")
wgrcSignalType = input.string("Binary", "Signal Calculation", options = ["Binary", "Candle Body", "Normalised Body"], group = "Divergence WGRC")
wgrcSmoothingType = input.string("SMA", "Smoothing MA", options = ["SMA", "EMA", "DEMA", "TEMA", "WMA", "HMA", "EHMA", "Zero-Lag Weak", "SuperSmoother"], group = "Divergence WGRC")
wgrcSmooth = input.int(3, "Smoothing Factor", minval = 2, group = "Divergence WGRC")
wgrcDivValue = input.string("WGRC", "Divergence Value", options = ["WGRC", "Smoothed WGRC", "WGRC - Smoothed WGRC"], group = "Divergence WGRC")

posRegColor = input.color(color.rgb(175, 213, 171, 33), "Positive Regular Divergence", group = "Divergence Types")
negRegColor = input.color(color.rgb(223, 107, 145, 33), "Negative Regular Divergence", group = "Divergence Types")
posHidColor = input.color(color.rgb(0, 230, 118, 33), "Positive Hidden Divergence", group = "Divergence Types")
negHidColor = input.color(color.rgb(255, 82, 82, 33), "Negative Hidden Divergence", group = "Divergence Types")
regStyleInput = input.string("Solid", "Regular Divergence Line Style", options = ["Solid", "Dashed", "Dotted"], group = "Divergence Types")
hidStyleInput = input.string("Solid", "Hidden Divergence Line Style", options = ["Solid", "Dashed", "Dotted"], group = "Divergence Types")
regWidth = input.int(2, "Regular Divergence Line Width", minval = 1, maxval = 5, group = "Divergence Types")
hidWidth = input.int(1, "Hidden Divergence Line Width", minval = 1, maxval = 5, group = "Divergence Types")

float ph = ta.pivothigh(sourceMode == "Close" ? close : high, prd, prd)
float pl = ta.pivotlow(sourceMode == "Close" ? close : low, prd, prd)
plotshape(showPivot ? ph : na, text = "H", title = "Pivot High", style = shape.labeldown, color = color.new(color.white, 100), textcolor = color.red, location = location.abovebar, offset = -prd)
plotshape(showPivot ? pl : na, text = "L", title = "Pivot Low", style = shape.labelup, color = color.new(color.white, 100), textcolor = color.lime, location = location.belowbar, offset = -prd)

var phPositions = array.new_int(20, 0)
var plPositions = array.new_int(20, 0)
var phVals = array.new_float(20, 0.0)
var plVals = array.new_float(20, 0.0)
if not na(ph)
    array.unshift(phPositions, bar_index), array.unshift(phVals, ph)
    array.pop(phPositions), array.pop(phVals)
if not na(pl)
    array.unshift(plPositions, bar_index), array.unshift(plVals, pl)
    array.pop(plPositions), array.pop(plVals)

posRegOrNegHid(src, cond) =>
    divlen = 0
    priceSrc = sourceMode == "Close" ? close : low
    if dontConfirm or src > src[1] or close > close[1]
        start = dontConfirm ? 0 : 1
        for x = 0 to maxpp - 1
            len = bar_index - array.get(plPositions, x) + prd
            if array.get(plPositions, x) == 0 or len > maxbars
                break
            ok = len > 5 and ((cond == 1 and src[start] > src[len] and priceSrc[start] < nz(array.get(plVals, x))) or (cond == 2 and src[start] < src[len] and priceSrc[start] > nz(array.get(plVals, x))))
            if ok
                slope1 = (src[start] - src[len]) / (len - start)
                virtual1 = src[start] - slope1
                slope2 = (close[start] - close[len]) / (len - start)
                virtual2 = close[start] - slope2
                arrived = true
                for y = 1 + start to len - 1
                    if src[y] < virtual1 or nz(close[y]) < virtual2
                        arrived := false
                        break
                    virtual1 -= slope1
                    virtual2 -= slope2
                if arrived
                    divlen := len
                    break
    divlen

negRegOrPosHid(src, cond) =>
    divlen = 0
    priceSrc = sourceMode == "Close" ? close : high
    if dontConfirm or src < src[1] or close < close[1]
        start = dontConfirm ? 0 : 1
        for x = 0 to maxpp - 1
            len = bar_index - array.get(phPositions, x) + prd
            if array.get(phPositions, x) == 0 or len > maxbars
                break
            ok = len > 5 and ((cond == 1 and src[start] < src[len] and priceSrc[start] > nz(array.get(phVals, x))) or (cond == 2 and src[start] > src[len] and priceSrc[start] < nz(array.get(phVals, x))))
            if ok
                slope1 = (src[start] - src[len]) / (len - start)
                virtual1 = src[start] - slope1
                slope2 = (close[start] - nz(close[len])) / (len - start)
                virtual2 = close[start] - slope2
                arrived = true
                for y = 1 + start to len - 1
                    if src[y] > virtual1 or nz(close[y]) > virtual2
                        arrived := false
                        break
                    virtual1 -= slope1
                    virtual2 -= slope2
                if arrived
                    divlen := len
                    break
    divlen

calculateDivs(enabled, indicator) =>
    posReg = enabled and (searchDiv == "Regular" or searchDiv == "Regular & Hidden") ? posRegOrNegHid(indicator, 1) : 0
    negReg = enabled and (searchDiv == "Regular" or searchDiv == "Regular & Hidden") ? negRegOrPosHid(indicator, 1) : 0
    posHid = enabled and (searchDiv == "Hidden" or searchDiv == "Regular & Hidden") ? negRegOrPosHid(indicator, 2) : 0
    negHid = enabled and (searchDiv == "Hidden" or searchDiv == "Regular & Hidden") ? posRegOrNegHid(indicator, 2) : 0
    [posReg, negReg, posHid, negHid]

[macdLine, macdSignal, macdHist] = mpbg.macd(macdSrc, macdFast, macdSlow, macdSmooth, macdMaType)
macdValue = macdDivValue == "Signal Line" ? macdSignal : macdDivValue == "Histogram" ? macdHist : macdLine
[qqeRsiMa, qqeTrailing] = mpbg.qqeLines(qqeSrc, qqeRsiLen, qqeSf, qqeWp, qqeMaType, "RSI")
qqeValue = qqeDivValue == "Trailing Line" ? qqeTrailing : qqeDivValue == "RSI MA - Trailing Line" ? qqeRsiMa - qqeTrailing : qqeRsiMa
rsiValue = ta.rsi(rsiSrc, rsiLen)
[stochK, stochD] = mpbg.stochastic(stochKLen, stochSmoothK, stochDLen)
stochValue = stochDivValue == "%D" ? stochD : stochDivValue == "%K - %D" ? stochK - stochD : stochK
[wgrc, smoothWgrc] = mpbg.weightedGreenRedCount(wgrcLen, wgrcSignalType, wgrcWeightingType, wgrcSmooth, wgrcSmoothingType)
wgrcValue = wgrcDivValue == "Smoothed WGRC" ? smoothWgrc : wgrcDivValue == "WGRC - Smoothed WGRC" ? wgrc - smoothWgrc : wgrc

var names = array.from("MACD Platinum", "QQE Advanced", "RSI", "Stoch", "WGRC", "External")
var posLines = array.new_line()
var negLines = array.new_line()

handleIndicator(idx, enabled, value) =>
    [posReg, negReg, posHid, negHid] = calculateDivs(enabled, value)
    hasPos = posReg > 0 or posHid > 0
    hasNeg = negReg > 0 or negHid > 0
    total = (posReg > 0 ? 1 : 0) + (negReg > 0 ? 1 : 0) + (posHid > 0 ? 1 : 0) + (negHid > 0 ? 1 : 0)
    if total >= showLimit
        start = dontConfirm ? 0 : 1
        if hasPos
            len = posReg > 0 ? posReg : posHid
            col = posReg > 0 ? posRegColor : posHidColor
            if showLines
                array.push(posLines, line.new(bar_index - len, sourceMode == "Close" ? close[len] : low[len], bar_index - start, sourceMode == "Close" ? close[start] : low[start], color = col, style = posReg > 0 ? mpbg.lineStyle(regStyleInput) : mpbg.lineStyle(hidStyleInput), width = posReg > 0 ? regWidth : hidWidth))
            if showLabels
                label.new(bar_index, math.min((1.0 - divLabelGap) * low, (1.0 - divLabelGap) * low[1]), array.get(names, idx), color = col, textcolor = color.white, style = label.style_label_up)
        if hasNeg
            len = negReg > 0 ? negReg : negHid
            col = negReg > 0 ? negRegColor : negHidColor
            if showLines
                array.push(negLines, line.new(bar_index - len, sourceMode == "Close" ? close[len] : high[len], bar_index - start, sourceMode == "Close" ? close[start] : high[start], color = col, style = negReg > 0 ? mpbg.lineStyle(regStyleInput) : mpbg.lineStyle(hidStyleInput), width = negReg > 0 ? regWidth : hidWidth))
            if showLabels
                label.new(bar_index, math.max((1.0 + divLabelGap) * high, (1.0 + divLabelGap) * high[1]), array.get(names, idx), color = col, textcolor = color.white, style = label.style_label_down)
    [posReg > 0, negReg > 0, posHid > 0, negHid > 0]

[pr0, nr0, ph0, nh0] = handleIndicator(0, calcMacdPlatinum, macdValue)
[pr1, nr1, ph1, nh1] = handleIndicator(1, calcQQEAdvanced, qqeValue)
[pr2, nr2, ph2, nh2] = handleIndicator(2, calcRsi, rsiValue)
[pr3, nr3, ph3, nh3] = handleIndicator(3, calcStoch, stochValue)
[pr4, nr4, ph4, nh4] = handleIndicator(4, calcWGRC, wgrcValue)
[pr5, nr5, ph5, nh5] = handleIndicator(5, calcExt, externalIndi)

posRegDetected = pr0 or pr1 or pr2 or pr3 or pr4 or pr5
negRegDetected = nr0 or nr1 or nr2 or nr3 or nr4 or nr5
posHidDetected = ph0 or ph1 or ph2 or ph3 or ph4 or ph5
negHidDetected = nh0 or nh1 or nh2 or nh3 or nh4 or nh5
alertcondition(posRegDetected, title = "Positive Regular Divergence Detected", message = "Positive Regular Divergence Detected")
alertcondition(negRegDetected, title = "Negative Regular Divergence Detected", message = "Negative Regular Divergence Detected")
alertcondition(posHidDetected, title = "Positive Hidden Divergence Detected", message = "Positive Hidden Divergence Detected")
alertcondition(negHidDetected, title = "Negative Hidden Divergence Detected", message = "Negative Hidden Divergence Detected")
