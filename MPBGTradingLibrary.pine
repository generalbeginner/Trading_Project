//@version=6
library("MPBGTradingLibrary")

// Moving averages and smoothing
export dema(series float src, simple int len) =>
    float ma1 = ta.ema(src, len)
    float ma2 = ta.ema(ma1, len)
    2.0 * ma1 - ma2

export tema(series float src, simple int len) =>
    float ma1 = ta.ema(src, len)
    float ma2 = ta.ema(ma1, len)
    float ma3 = ta.ema(ma2, len)
    3.0 * (ma1 - ma2) + ma3

export hma(series float src, simple int len) =>
    int len1 = math.max(1, math.floor(len / 2))
    int len2 = math.max(1, math.round(math.sqrt(len)))
    ta.wma(2.0 * ta.wma(src, len1) - ta.wma(src, len), len2)

export ehma(series float src, simple int len) =>
    int len1 = math.max(1, math.floor(len / 2))
    int len2 = math.max(1, math.floor(math.sqrt(len)))
    ta.ema(2.0 * ta.ema(src, len1) - ta.ema(src, len), len2)

export zeroLagWeak(series float src, simple int len) =>
    int lag = math.floor((len - 1) / 2)
    float srcAdj = src + (src - nz(src[lag], src))
    ta.ema(srcAdj, len)

export superSmoother(series float src, simple int len) =>
    float a = math.exp(-1.414 * math.pi / len)
    float b = 2.0 * a * math.cos(1.414 * math.pi / len)
    float c2 = b
    float c3 = -a * a
    float c1 = 1.0 - c2 - c3
    float ss = 0.0
    ss := c1 * (src + nz(src[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

export ma(series float src, simple int len, simple string maType) =>
    switch maType
        "SMA" => ta.sma(src, len)
        "EMA" => ta.ema(src, len)
        "DEMA" => dema(src, len)
        "TEMA" => tema(src, len)
        "RMA" => ta.rma(src, len)
        "SMMA (RMA)" => ta.rma(src, len)
        "WMA" => ta.wma(src, len)
        "VWMA" => ta.vwma(src, len)
        "HMA" => hma(src, len)
        "EHMA" => ehma(src, len)
        "Zero-Lag Weak" => zeroLagWeak(src, len)
        "SuperSmoother" => superSmoother(src, len)
        => ta.ema(src, len)

// Oscillators
export ehlersRSIH(series float src, simple int len) =>
    float pix2 = 2.0 * math.pi
    float cu = 0.0
    float cd = 0.0
    for count = 1 to len
        float chg = src[count] - src[count - 1]
        float absChg = math.abs(chg)
        float cosPart = math.cos(pix2 * count / (len + 1))
        if chg < 0
            cu += (1.0 - cosPart) * absChg
        else if chg > 0
            cd += (1.0 - cosPart) * absChg
    nz((cu - cd) / (cu + cd))

export stochasticRsi(series float src, simple int rsiLen, simple int stochLen, simple int smoothK) =>
    float rsiValue = ta.rsi(src, rsiLen)
    float lowestRsi = ta.lowest(rsiValue, stochLen)
    float highestRsi = ta.highest(rsiValue, stochLen)
    float raw = highestRsi != lowestRsi ? 100.0 * (rsiValue - lowestRsi) / (highestRsi - lowestRsi) : 0.0
    ta.sma(raw, smoothK)

export rsi(series float src, simple int len, simple string rsiType) =>
    switch rsiType
        "Stochastic RSI" => stochasticRsi(src, len, len, 1)
        "Ehlers' RSIH" => ehlersRSIH(src, len)
        => ta.rsi(src, len)

export rsiVariant(series float src, simple int rsiLen, simple string rsiType, simple int stochLen, simple int smoothK) =>
    switch rsiType
        "Stochastic RSI" => stochasticRsi(src, rsiLen, stochLen, smoothK)
        "Ehlers' RSIH" => ehlersRSIH(src, rsiLen)
        => ta.rsi(src, rsiLen)

export macd(series float src, simple int fastLen, simple int slowLen, simple int signalLen, simple string maType) =>
    float fast = ma(src, fastLen, maType)
    float slow = ma(src, slowLen, maType)
    float macdLine = fast - slow
    float signalLine = ma(macdLine, signalLen, maType)
    float hist = macdLine - signalLine
    [macdLine, signalLine, hist]

export qqeLines(series float src, simple int rsiLen, simple int sf, simple float wp, simple string maType, simple string rsiType) =>
    int wildersPeriod = rsiLen * 2 - 1
    float rsiValue = rsi(src, rsiLen, rsiType)
    float rsiMa = ma(rsiValue, sf, maType)
    float atrRsi = math.abs(rsiMa[1] - rsiMa)
    float maAtrRsi = ma(atrRsi, wildersPeriod, maType)
    float dar = ma(maAtrRsi, wildersPeriod, maType) * wp
    float newShortBand = rsiMa + dar
    float shortBand = 0.0
    shortBand := rsiMa[1] < shortBand[1] and rsiMa < shortBand[1] ? math.min(shortBand[1], newShortBand) : newShortBand
    float newLongBand = rsiMa - dar
    float longBand = 0.0
    longBand := rsiMa[1] > longBand[1] and rsiMa > longBand[1] ? math.max(longBand[1], newLongBand) : newLongBand
    float trend = 0.0
    bool crossShort = ta.cross(rsiMa, shortBand[1])
    bool crossLong = ta.cross(rsiMa, longBand[1])
    trend := crossShort ? 1.0 : crossLong ? -1.0 : nz(trend[1], 1.0)
    float trailingLine = trend == 1.0 ? longBand : shortBand
    [rsiMa, trailingLine]

export qqeLinesAdvanced(series float src, simple int rsiLen, simple int sf, simple float wp, simple string maType, simple string rsiType, simple int stochLen, simple int stochSmoothK) =>
    int wildersPeriod = rsiLen * 2 - 1
    float rsiValue = rsiVariant(src, rsiLen, rsiType, stochLen, stochSmoothK)
    float rsiMa = ma(rsiValue, sf, maType)
    float atrRsi = math.abs(rsiMa[1] - rsiMa)
    float maAtrRsi = ma(atrRsi, wildersPeriod, maType)
    float dar = ma(maAtrRsi, wildersPeriod, maType) * wp
    float newShortBand = rsiMa + dar
    float shortBand = 0.0
    shortBand := rsiMa[1] < shortBand[1] and rsiMa < shortBand[1] ? math.min(shortBand[1], newShortBand) : newShortBand
    float newLongBand = rsiMa - dar
    float longBand = 0.0
    longBand := rsiMa[1] > longBand[1] and rsiMa > longBand[1] ? math.max(longBand[1], newLongBand) : newLongBand
    float trend = 0.0
    bool crossShort = ta.cross(rsiMa, shortBand[1])
    bool crossLong = ta.cross(rsiMa, longBand[1])
    trend := crossShort ? 1.0 : crossLong ? -1.0 : nz(trend[1], 1.0)
    float trailingLine = trend == 1.0 ? longBand : shortBand
    [rsiMa, trailingLine]

export qqeQmpSignals(series float qqeSrc, simple int rsiLen, simple int sf, simple float wp, simple string qqeMaType, simple string rsiType, series float macdLine, series float signalLine) =>
    [rsiMa, trailingLine] = qqeLines(qqeSrc, rsiLen, sf, wp, qqeMaType, rsiType)
    bool macdBull = ta.barssince(ta.crossover(macdLine, signalLine)) < ta.barssince(ta.crossunder(macdLine, signalLine))
    bool macdBear = ta.barssince(ta.crossover(macdLine, signalLine)) > ta.barssince(ta.crossunder(macdLine, signalLine))
    bool longSituation = macdBull and rsiMa > trailingLine
    bool shortSituation = macdBear and rsiMa < trailingLine
    bool longOverShort = ta.barssince(longSituation)[1] > ta.barssince(shortSituation)[1]
    bool shortOverLong = ta.barssince(shortSituation)[1] > ta.barssince(longSituation)[1]
    bool upSwitch = longSituation and longOverShort and barstate.isconfirmed
    bool downSwitch = shortSituation and shortOverLong and barstate.isconfirmed
    [upSwitch, downSwitch]

export qqeQmpSignalsAdvanced(series float qqeSrc, simple int rsiLen, simple int sf, simple float wp, simple string qqeMaType, simple string rsiType, simple int stochLen, simple int stochSmoothK, series float macdLine, series float signalLine) =>
    [rsiMa, trailingLine] = qqeLinesAdvanced(qqeSrc, rsiLen, sf, wp, qqeMaType, rsiType, stochLen, stochSmoothK)
    bool macdBull = ta.barssince(ta.crossover(macdLine, signalLine)) < ta.barssince(ta.crossunder(macdLine, signalLine))
    bool macdBear = ta.barssince(ta.crossover(macdLine, signalLine)) > ta.barssince(ta.crossunder(macdLine, signalLine))
    bool longSituation = macdBull and rsiMa > trailingLine
    bool shortSituation = macdBear and rsiMa < trailingLine
    bool longOverShort = ta.barssince(longSituation)[1] > ta.barssince(shortSituation)[1]
    bool shortOverLong = ta.barssince(shortSituation)[1] > ta.barssince(longSituation)[1]
    bool upSwitch = longSituation and longOverShort and barstate.isconfirmed
    bool downSwitch = shortSituation and shortOverLong and barstate.isconfirmed
    [upSwitch, downSwitch]

export manualRsi(series float src, simple int len) =>
    float chg = ta.change(src)
    float up = ta.rma(math.max(chg, 0.0), len)
    float down = ta.rma(-math.min(chg, 0.0), len)
    down == 0.0 ? 100.0 : up == 0.0 ? 0.0 : 100.0 - (100.0 / (1.0 + up / down))

export stochastic(simple int periodK, simple int smoothK, simple int periodD) =>
    float k = ta.sma(ta.stoch(close, high, low, periodK), smoothK)
    float d = ta.sma(k, periodD)
    [k, d]

// Bands and candle-derived signals
export bollinger(series float src, simple int len, simple float mult, simple string maType) =>
    float basis = ma(src, len, maType)
    float dev = mult * ta.stdev(src, len)
    [basis, basis + dev, basis - dev]

export candleSignal(simple string signalType) =>
    float candleRange = high - low
    switch signalType
        "Binary" => close > open ? 1.0 : close < open ? -1.0 : 0.0
        "Candle Body" => close - open
        "Normalised Body" => candleRange != 0.0 ? (close - open) / candleRange : 0.0
        => 0.0

export weightedGreenRedCount(simple int len, simple string signalType, simple string weightingType, simple int smoothLen, simple string smoothingType) =>
    float signal = candleSignal(signalType)
    float weighted = weightingType == "HMA" ? hma(signal, len) : ta.wma(signal, len)
    float smoothed = ma(weighted, smoothLen, smoothingType)
    [weighted, smoothed]

// Ehlers Synthetic Oscillator
export rms(series float src, simple int len) =>
    float s2 = math.sum(src * src, len)
    s2 != 0.0 ? math.sqrt(s2 / len) : 0.0

export highPass(series float src, simple int period) =>
    float q = math.exp(-1.414 * math.pi / period)
    float c1 = 2.0 * q * math.cos(1.414 * math.pi / period)
    float c2 = q * q
    float a0 = (1.0 + c1 + c2) / 4.0
    float hp = 0.0
    if bar_index >= 4
        hp := nz(a0 * (src - 2.0 * src[1] + src[2]) + c1 * hp[1] - c2 * hp[2])
    hp

export ehlersSuperSmoother(series float src, simple int period) =>
    float q = math.exp(-1.414 * math.pi / period)
    float c1 = 2.0 * q * math.cos(1.414 * math.pi / period)
    float c2 = q * q
    float a0 = (1.0 - c1 + c2) / 2.0
    float ss = src
    if bar_index >= 4
        ss := a0 * (src + src[1]) + c1 * ss[1] - c2 * ss[2]
    ss

export ultimateSmoother(series float src, simple int period) =>
    float q = math.exp(-1.414 * math.pi / period)
    float c1 = 2.0 * q * math.cos(1.414 * math.pi / period)
    float c2 = q * q
    float a0 = (1.0 + c1 + c2) / 4.0
    float us = src
    if bar_index >= 4
        us := (1.0 - a0) * src + (2.0 * a0 - c1) * src[1] + (c2 - a0) * src[2] + c1 * nz(us[1]) - c2 * nz(us[2])
    us

export hann(series float src, simple int len) =>
    float filt = 0.0
    float coef = 0.0
    for c = 1 to len
        float p = math.cos(2.0 * math.pi * c / (len + 1))
        filt += 1.0 - nz(p * src[c - 1])
        coef += 1.0 - p
    coef != 0.0 ? filt / coef : 0.0

export syntheticOscillator(series float src, simple int lowerBound, simple int upperBound) =>
    float price = hann(src, 12)
    float hp = highPass(price, upperBound)
    float lp = ehlersSuperSmoother(hp, lowerBound)
    float reRms = rms(lp, 100)
    float re = reRms != 0.0 ? lp / reRms : 0.0
    float roc = re - re[1]
    float imRms = rms(roc, 100)
    float im = imRms != 0.0 ? roc / imRms : 0.0
    float denom = roc * im - (im - im[1]) * re
    float dc = denom != 0.0 ? 6.28 * (re * re + im * im) / denom : 0.0
    dc := math.max(lowerBound, math.min(upperBound, dc))
    int mid = int(math.sqrt(lowerBound * upperBound))
    float bp = ultimateSmoother(highPass(src, mid), mid)
    var float phase = 0.0
    phase += 2.0 * math.pi / dc
    if ta.crossover(bp, 0.0)
        phase := math.pi / dc
    if ta.crossunder(bp, 0.0)
        phase := math.pi + math.pi / dc
    float so = math.sin(phase)
    switch
        phase > 0.0 and phase < math.pi / 2.0 and so < so[1] => so[1]
        phase > math.pi and phase < 3.0 * math.pi / 2.0 and so > so[1] => so[1]
        => so

// Shared display helpers
export lineStyle(simple string styleName) =>
    switch styleName
        "Dotted" => line.style_dotted
        "Dashed" => line.style_dashed
        => line.style_solid

export fibPrice(series float startPrice, series float height, simple float level) =>
    startPrice + height * level

export crossingLevel(series float src, series float level) =>
    (level > src and level < src[1]) or (level < src and level > src[1])
